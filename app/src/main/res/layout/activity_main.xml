<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#001F18">

    <ImageView
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_gravity="center"
        android:src="@drawable/logo_app"
        android:alpha="0.06"
        android:scaleType="fitCenter" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:src="@drawable/logo_app"
                android:scaleType="fitCenter"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cálculo de Impuestos en Minutos"
                android:textColor="#FFD700"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resultados Profesionales en Instantes"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Titular de la Consulta"
                android:inputType="textCapWords|textPersonName"
                android:textColor="#FFFFFF"
                android:background="@drawable/edittext_gold_glow"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <EditText
                android:id="@+id/etDespacho"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre del Despacho (opcional)"
                android:inputType="textCapWords"
                android:textColor="#FFFFFF"
                android:background="@drawable/edittext_gold_glow"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <EditText
                android:id="@+id/etSueldoBruto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Sueldo bruto mensual (MXN)"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:background="@drawable/edittext_gold_glow"
                android:padding="16dp"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/etDeducciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Deducciones manuales"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:background="@drawable/edittext_gold_glow"
                android:padding="16dp"
                android:layout_marginBottom="16dp" />

            <Switch
                android:id="@+id/switchIMSS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calcular cuota IMSS obrera (2.375%)"
                android:textColor="#FFD700"
                android:thumbTint="#FFD700"
                android:trackTint="#004D40"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btnCalcular"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="CALCULAR ISR"
                android:backgroundTint="#D4AF37"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="30dp" />

            <TextView
                android:id="@+id/tvResultado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/card_gold_glow"
                android:padding="20dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvEmote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="50sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardTipFiscal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardBackgroundColor="#AA004D39"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡"
                        android:textSize="20sp"
                        android:layout_marginEnd="12dp"/>
                    <TextView
                        android:id="@+id/tvTipTexto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textStyle="italic"
                        android:maxLines="4"
                        android:ellipsize="none"
                        android:scrollHorizontally="false" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/chartGrafica"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:visibility="gone"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPremium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#1A2A1A"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="💎 Plan PREMIUM"
                                android:textColor="#FF8F00"
                                android:textSize="16sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$699/año"
                                android:textColor="#FFD700"
                                android:textSize="16sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Aprox. $58 al mes"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:layout_marginBottom="10dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✅  Sin anuncios\n✅  Reportes PDF profesionales\n✅  Cálculos ilimitados\n✅  Tablas SAT siempre actualizadas"
                            android:textColor="#CCCCCC"
                            android:textSize="12sp"
                            android:layout_marginBottom="12dp"/>
                        <Button
                            android:id="@+id/btnUpgradePremium"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:text="SUSCRIBIRME AL PREMIUM"
                            android:backgroundTint="#FF8F00"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSuperPremium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#1A1A0A"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="👑 Súper Premium"
                                    android:textColor="#FFD700"
                                    android:textSize="16sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=" ⭐ Popular"
                                    android:textColor="#FF8F00"
                                    android:textSize="11sp"
                                    android:textStyle="bold"/>
                            </LinearLayout>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$899/año"
                                android:textColor="#FFD700"
                                android:textSize="16sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Solo $200 más que Premium"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:layout_marginBottom="10dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✅  Todo lo del Plan Premium\n✅  Nombre de tu Despacho en el PDF\n✅  Gráficas de barras comparativas\n✅  Firma profesional como elaborador\n✅  Acceso prioritario a Asesoría IA"
                            android:textColor="#CCCCCC"
                            android:textSize="12sp"
                            android:layout_marginBottom="12dp"/>
                        <Button
                            android:id="@+id/btnUpgradeSuperPremium"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:text="SUSCRIBIRME AL SÚPER PREMIUM"
                            android:backgroundTint="#D4AF37"
                            android:textColor="#000000"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <com.google.android.gms.ads.AdView
                android:id="@+id/adView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:adSize="BANNER"
                app:adUnitId="ca-app-pub-3940256099942544/6300978111" />

        </LinearLayout>
    </ScrollView>
